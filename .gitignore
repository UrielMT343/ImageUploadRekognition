# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Terraform Files - CRITICAL
# Ignore the state files. They contain a map of your resources and can hold sensitive data.
*.tfstate
*.tfstate.backup

# Ignore the .terraform directory where providers are downloaded
.terraform/

# Ignore the plan cache file. It can also contain sensitive data.
*.tfplan

# Ignore generated zip files for Lambda
# We added this to our Terraform configuration
lambda_function.zip


# Next.js / Node.js Dependency and Build folders
# These are generated and can be huge
node_modules/
.next/


# Environment variables - NEVER commit secrets
# Contains secret keys and environment-specific settings
.env.local
.env.development.local
.env.test.local
.env.production.local


# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# Operating System / Editor specific files
.DS_Store
Thumbs.db
.vscode/